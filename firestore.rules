rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isPostOwner(post) {
      return isAuthenticated() && request.auth.uid == post.uid;
    }

    function isValidContent(content) {
      return content is string &&
             content.size() >= 3 &&
             content.size() <= 280;
    }

    match /posts/{postId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() &&
        request.resource.data.keys().hasOnly([
          'uid',
          'display_name',
          'username',
          'content',
          'created_at',
          'likes_count',
          'comments_count'
        ]) &&
        request.resource.data.uid is string &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.display_name is string &&
        request.resource.data.display_name.size() > 0 &&
        request.resource.data.username is string &&
        request.resource.data.username.size() > 0 &&
        isValidContent(request.resource.data.content) &&
        request.resource.data.created_at is timestamp &&
        request.resource.data.likes_count is int &&
        request.resource.data.likes_count == 0 &&
        request.resource.data.comments_count is int &&
        request.resource.data.comments_count == 0;

      allow update: if isAuthenticated() &&
        isPostOwner(resource.data) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['content']) &&
        isValidContent(request.resource.data.content);

      allow delete: if isAuthenticated() &&
        isPostOwner(resource.data);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}